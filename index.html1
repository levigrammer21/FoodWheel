<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no"/>
<meta name="mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<title>MicroMMO</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,400&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0c10;--bg2:#0f1218;--bg3:#151a22;
  --surface:#1a2030;--surface2:#1f2838;--surface3:#253040;
  --border:#2a3448;--border2:#3d4f6e;--border3:#5a70a0;
  --gold:#c9943a;--gold2:#e8b84d;--gold3:#fff0b3;
  --steel:#4a9eda;--steel2:#6ab8f0;--steel3:#a0d4ff;
  --crimson:#b03030;--crimson2:#e04040;
  --green:#27ae60;--green2:#2ecc71;
  --purple:#7c4dff;--purple2:#9c6dff;
  --text:#dce8f5;--text2:#8fa8c8;--text3:#4a6080;
  --common:#9ca3af;--uncommon:#34d399;--rare:#60a5fa;--epic:#c084fc;--legendary:#fbbf24;
  --nav-h:62px;--hdr-h:52px;
}
html{height:100%;background:var(--bg)}
body{font-family:'Crimson Pro',Georgia,serif;color:var(--text);
  height:100%;display:flex;justify-content:center;background:var(--bg);overflow:hidden}
#app{width:100%;max-width:480px;height:100vh;height:100dvh;
  display:flex;flex-direction:column;background:var(--bg2);overflow:hidden}

/* ── SCREENS ── */
.screen{display:none;flex-direction:column;height:100%;overflow:hidden}
.screen.active{display:flex}

/* ── AUTH ── */
#auth-screen,#username-screen{
  align-items:center;justify-content:center;padding:1.5rem;gap:1.2rem;
  background:linear-gradient(160deg,#080c14 0%,#0f1a2e 50%,#080e14 100%);overflow-y:auto}
.auth-logo-text{font-family:'Cinzel',serif;font-size:2.8rem;font-weight:900;text-align:center;
  background:linear-gradient(135deg,var(--steel),var(--gold2),var(--steel2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:0.08em}
.auth-logo-sub{color:var(--text3);font-style:italic;font-size:0.88rem;
  letter-spacing:0.15em;text-transform:uppercase;text-align:center}
.auth-card{background:var(--surface);border:1px solid var(--border2);border-radius:16px;
  padding:1.5rem;width:100%;max-width:340px;box-shadow:0 30px 80px rgba(0,0,0,0.6)}
.tab-row{display:flex;background:var(--bg3);border-radius:8px;padding:3px;margin-bottom:1.2rem;gap:3px}
.tab-btn{flex:1;padding:0.5rem;border:none;border-radius:6px;background:transparent;
  color:var(--text3);font-family:'Cinzel',serif;font-size:0.75rem;cursor:pointer;
  transition:all 0.2s;letter-spacing:0.05em}
.tab-btn.active{background:var(--steel);color:white}
.form-group{margin-bottom:0.85rem}
.form-label{display:block;font-size:0.7rem;color:var(--text3);margin-bottom:0.3rem;
  font-family:'Cinzel',serif;letter-spacing:0.08em;text-transform:uppercase}
.form-input{width:100%;padding:0.7rem 0.9rem;background:var(--bg3);border:1px solid var(--border);
  border-radius:8px;color:var(--text);font-family:'Crimson Pro',serif;font-size:1rem;
  outline:none;transition:border-color 0.2s}
.form-input:focus{border-color:var(--steel)}
.error-box{background:rgba(176,48,48,0.2);border:1px solid var(--crimson);border-radius:8px;
  padding:0.6rem;font-size:0.82rem;color:var(--crimson2);text-align:center;margin-bottom:0.75rem}
.divider{display:flex;align-items:center;gap:0.75rem;margin:0.6rem 0;color:var(--text3);font-size:0.78rem}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border)}

/* ── BUTTONS ── */
.btn{display:flex;align-items:center;justify-content:center;gap:0.5rem;
  width:100%;padding:0.8rem;border:none;border-radius:10px;
  font-family:'Cinzel',serif;font-size:0.82rem;font-weight:600;
  cursor:pointer;transition:all 0.18s;letter-spacing:0.06em;margin-bottom:0.5rem}
.btn:last-child{margin-bottom:0}
.btn:active{transform:scale(0.96)}
.btn:disabled{opacity:0.45;cursor:not-allowed;transform:none!important}
.btn-steel{background:linear-gradient(135deg,#2a6090,var(--steel));color:white;box-shadow:0 4px 16px rgba(74,158,218,0.3)}
.btn-steel:hover:not(:disabled){box-shadow:0 6px 22px rgba(74,158,218,0.5);transform:translateY(-1px)}
.btn-gold{background:linear-gradient(135deg,#6b4a10,var(--gold));color:#1a0f00;box-shadow:0 4px 16px rgba(201,148,58,0.25)}
.btn-gold:hover:not(:disabled){transform:translateY(-1px)}
.btn-green{background:linear-gradient(135deg,#1a5a30,var(--green2));color:white}
.btn-purple{background:linear-gradient(135deg,#3a1a80,var(--purple2));color:white}
.btn-ghost{background:var(--surface2);color:var(--text2);border:1px solid var(--border)}
.btn-ghost:hover{border-color:var(--border2);color:var(--text)}
.btn-danger{background:linear-gradient(135deg,#5a1010,var(--crimson));color:white}
.btn-sm{padding:0.45rem 0.75rem;font-size:0.72rem;border-radius:7px;width:auto;margin-bottom:0}

/* ── HEADER ── */
#header{height:var(--hdr-h);background:var(--bg3);border-bottom:1px solid var(--border);
  padding:0 0.85rem;display:flex;align-items:center;gap:0.6rem;flex-shrink:0;z-index:10}
.hdr-logo{font-family:'Cinzel',serif;font-size:1.05rem;font-weight:700;
  background:linear-gradient(135deg,var(--steel),var(--gold2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;flex:1}
.hdr-level{font-family:'Cinzel',serif;font-size:0.75rem;color:var(--gold2);
  background:var(--surface2);border:1px solid var(--border2);border-radius:6px;padding:0.18rem 0.45rem}
.hdr-hp{font-size:0.72rem;color:var(--crimson2);font-family:'Cinzel',serif}
.hdr-avatar{width:32px;height:32px;background:var(--surface2);border:2px solid var(--border2);
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:1rem;cursor:pointer;overflow:hidden;flex-shrink:0}
.hdr-avatar img{width:100%;height:100%;object-fit:cover;border-radius:50%}

/* ── CONTENT ── */
#content{flex:1;overflow-y:auto;overflow-x:hidden;padding:0.85rem;
  -webkit-overflow-scrolling:touch}
#content::-webkit-scrollbar{width:3px}
#content::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* ── NAV ── */
#nav{height:var(--nav-h);background:var(--bg3);border-top:1px solid var(--border);
  display:flex;align-items:center;flex-shrink:0;z-index:10}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  height:100%;border:none;background:transparent;color:var(--text3);
  font-family:'Cinzel',serif;font-size:0.52rem;cursor:pointer;gap:0.12rem;
  transition:color 0.2s;letter-spacing:0.04em;padding:0}
.nav-btn.active{color:var(--gold2)}
.nav-icon{font-size:1.2rem;line-height:1;display:block}
.nav-center{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-start}
.nav-walk{width:52px;height:52px;background:linear-gradient(135deg,#1a4a70,var(--steel));
  border-radius:50%;border:3px solid var(--bg3);display:flex;align-items:center;
  justify-content:center;font-size:1.4rem;cursor:pointer;margin-top:-20px;
  box-shadow:0 4px 20px rgba(74,158,218,0.5);transition:all 0.18s;
  color:white;overflow:hidden;flex-shrink:0}
.nav-walk img{width:55%;height:55%;object-fit:contain}
.nav-walk:active{transform:scale(0.88)}
.nav-walk.no-energy{background:linear-gradient(135deg,#1a1a2e,#2a2a40);
  box-shadow:0 2px 8px rgba(0,0,0,0.4);cursor:not-allowed}
@keyframes walkPulse{
  0%,100%{box-shadow:0 4px 20px rgba(74,158,218,0.5)}
  50%{box-shadow:0 4px 32px rgba(74,158,218,0.9),0 0 48px rgba(74,158,218,0.2)}}
.nav-walk:not(.no-energy){animation:walkPulse 2.5s ease-in-out infinite}

/* ── CARDS ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:0.9rem;margin-bottom:0.7rem}
.card-title{font-family:'Cinzel',serif;font-size:0.68rem;color:var(--text3);
  text-transform:uppercase;letter-spacing:0.12em;margin-bottom:0.7rem;
  display:flex;align-items:center;gap:0.4rem}
.card-title::after{content:'';flex:1;height:1px;background:var(--border)}
.card-title span{color:var(--text3)}

/* ── PLAYER BANNER ── */
.player-banner{background:linear-gradient(135deg,var(--surface),var(--surface2));
  border:1px solid var(--border2);border-radius:12px;padding:0.9rem;
  margin-bottom:0.7rem;display:flex;gap:0.9rem;align-items:center}
.p-avatar{width:58px;height:58px;background:var(--bg3);border:2px solid var(--border2);
  border-radius:12px;display:flex;align-items:center;justify-content:center;
  font-size:2rem;flex-shrink:0;overflow:hidden}
.p-avatar img{width:100%;height:100%;object-fit:cover;border-radius:10px}
.p-info{flex:1;min-width:0}
.p-name{font-family:'Cinzel',serif;font-size:0.95rem;font-weight:700;color:var(--gold2);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.p-class{font-size:0.78rem;color:var(--text3);margin-bottom:0.4rem}

/* ── BARS ── */
.bar-wrap{margin-bottom:0.35rem}
.bar-labels{display:flex;justify-content:space-between;font-size:0.72rem;color:var(--text3);margin-bottom:0.18rem}
.bar{height:7px;background:var(--bg3);border-radius:4px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px;transition:width 0.5s ease}
.bar-hp .bar-fill{background:linear-gradient(90deg,#7a1515,var(--crimson2))}
.bar-exp .bar-fill{background:linear-gradient(90deg,#1a5a90,var(--steel2))}
.bar-energy .bar-fill{background:linear-gradient(90deg,#7a4a10,var(--gold))}
.bar-quest .bar-fill{background:linear-gradient(90deg,#1a5a30,var(--green2))}
.bar-arena .bar-fill{background:linear-gradient(90deg,#4a1a80,var(--purple2))}

/* ── STAT BADGES ── */
.stat-row{display:flex;gap:0.4rem;flex-wrap:wrap;margin-top:0.5rem}
.stat-badge{background:var(--bg3);border:1px solid var(--border);border-radius:7px;
  padding:0.35rem 0.6rem;font-size:0.78rem;display:flex;align-items:center;gap:0.25rem}
.stat-badge em{color:var(--text3);font-style:normal}
.stat-badge strong{color:var(--gold2)}

/* ── CURRENCY ── */
.curr-row{display:flex;gap:0.5rem}
.curr-item{flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:9px;padding:0.55rem;text-align:center}
.curr-amount{font-family:'Cinzel',serif;font-size:0.95rem;color:var(--gold2);font-weight:600}
.curr-label{font-size:0.65rem;color:var(--text3);margin-top:0.1rem}

/* ── FEED ── */
.feed-empty{text-align:center;padding:3rem 1rem;color:var(--text3);font-style:italic;font-size:0.9rem}
.feed-item{background:var(--surface);border:1px solid var(--border);border-radius:10px;
  padding:0.65rem 0.85rem;display:flex;align-items:center;gap:0.7rem;margin-bottom:0.45rem}
@keyframes feedIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.feed-item{animation:feedIn 0.25s ease}
.feed-icon{width:32px;height:32px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.4rem}
.feed-icon img{width:32px;height:32px;object-fit:contain;border-radius:4px}
.feed-text{flex:1;font-size:0.85rem;color:var(--text2);line-height:1.3}
.feed-text strong{color:var(--text)}
.feed-badge{font-size:0.72rem;font-family:'Cinzel',serif;padding:0.18rem 0.45rem;
  border-radius:5px;background:var(--surface2);white-space:nowrap}

/* ── SECTION HEADER ── */
.section-hdr{font-family:'Cinzel',serif;font-size:0.65rem;text-transform:uppercase;
  letter-spacing:0.15em;color:var(--text3);margin:0.85rem 0 0.5rem;
  display:flex;align-items:center;gap:0.5rem}
.section-hdr::after{content:'';flex:1;height:1px;background:var(--border)}

/* ── GEAR / INVENTORY ── */
.equip-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.45rem;margin-bottom:0.7rem}
.equip-slot{background:var(--bg3);border:1px solid var(--border);border-radius:9px;
  padding:0.6rem;display:flex;align-items:center;gap:0.5rem;cursor:pointer;
  transition:border-color 0.2s;min-height:52px}
.equip-slot:hover,.equip-slot.filled{border-color:var(--border2)}
.es-icon{width:28px;height:28px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
.es-icon img{width:28px;height:28px;object-fit:contain}
.es-info{flex:1;min-width:0}
.es-name{font-size:0.75rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.es-stat{font-size:0.65rem;color:var(--text3)}
.es-empty{font-size:0.72rem;color:var(--text3);font-style:italic}
.es-type{font-size:0.6rem;color:var(--text3);flex-shrink:0}
.inv-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0.45rem}
.inv-item{background:var(--bg3);border:1px solid var(--border);border-radius:9px;
  padding:0.6rem;text-align:center;cursor:pointer;transition:all 0.18s;position:relative}
.inv-item:hover{border-color:var(--border2);transform:translateY(-1px)}
.inv-icon{width:40px;height:40px;margin:0 auto 0.25rem;display:flex;align-items:center;justify-content:center;font-size:1.6rem}
.inv-icon img{width:40px;height:40px;object-fit:contain}
.inv-item-name{font-size:0.68rem;font-weight:600;line-height:1.2;margin-bottom:0.1rem}
.inv-item-stat{font-size:0.62rem;color:var(--text3)}
.inv-empty{text-align:center;padding:2rem;color:var(--text3);font-style:italic;font-size:0.88rem}

/* roll quality badge */
.quality-badge{position:absolute;top:3px;right:3px;font-size:0.55rem;font-family:'Cinzel',serif;
  padding:1px 4px;border-radius:4px;font-weight:700}

/* ── QUESTS ── */
.quest-item{background:var(--bg3);border:1px solid var(--border);border-radius:10px;
  padding:0.75rem;margin-bottom:0.5rem}
.quest-top{display:flex;align-items:center;gap:0.6rem;margin-bottom:0.5rem}
.quest-icon{font-size:1.3rem;flex-shrink:0}
.quest-info{flex:1}
.quest-name{font-family:'Cinzel',serif;font-size:0.82rem;color:var(--text)}
.quest-desc{font-size:0.75rem;color:var(--text3);margin-top:0.1rem}
.quest-reward{font-size:0.72rem;color:var(--gold2);font-family:'Cinzel',serif}
.quest-done{color:var(--green2)!important}

/* ── ARENA ── */
.arena-tier{text-align:center;padding:1rem 0;margin-bottom:0.5rem}
.arena-tier-name{font-family:'Cinzel',serif;font-size:1.2rem;font-weight:700;margin-bottom:0.2rem}
.arena-tier-sub{font-size:0.8rem;color:var(--text3);margin-bottom:0.75rem}

/* ── MARKET ── */
.market-item{background:var(--bg3);border:1px solid var(--border);border-radius:10px;
  padding:0.75rem;margin-bottom:0.5rem;display:flex;align-items:center;gap:0.75rem}
.market-icon{font-size:1.4rem;flex-shrink:0;width:36px;text-align:center}
.market-info{flex:1;min-width:0}
.market-name{font-size:0.85rem;font-weight:600}
.market-seller{font-size:0.7rem;color:var(--text3);margin-top:0.1rem}
.market-stat{font-size:0.72rem;color:var(--text2);margin-top:0.1rem}
.market-price{font-family:'Cinzel',serif;font-size:0.9rem;color:var(--gold2);white-space:nowrap}

/* ── SHOP ── */
.shop-item{background:var(--bg3);border:1px solid var(--border);border-radius:10px;
  padding:0.75rem;margin-bottom:0.5rem;display:flex;align-items:center;gap:0.75rem}
.shop-icon{font-size:1.6rem;flex-shrink:0;width:40px;text-align:center}
.shop-info{flex:1;min-width:0}
.shop-name{font-size:0.88rem;font-weight:600;margin-bottom:0.1rem}
.shop-desc{font-size:0.72rem;color:var(--text3)}
.shop-price{font-family:'Cinzel',serif;font-size:0.88rem;color:var(--gold2);white-space:nowrap;text-align:right}

/* ── BANK ── */
.bank-display{text-align:center;padding:1rem;background:var(--bg3);border-radius:10px;margin-bottom:0.75rem}
.bank-amount{font-family:'Cinzel',serif;font-size:2rem;color:var(--gold2);font-weight:700}
.bank-label{font-size:0.78rem;color:var(--text3);margin-top:0.2rem}
.bank-input-row{display:flex;gap:0.5rem;margin-bottom:0.5rem}
.bank-input{flex:1;padding:0.65rem 0.8rem;background:var(--bg3);border:1px solid var(--border);
  border-radius:8px;color:var(--text);font-family:'Crimson Pro',serif;font-size:1rem;outline:none}
.bank-input:focus{border-color:var(--gold)}

/* ── LEADERBOARD ── */
.lb-row{display:flex;align-items:center;gap:0.7rem;padding:0.55rem 0;border-bottom:1px solid var(--border)}
.lb-row:last-child{border-bottom:none}
.lb-rank{font-family:'Cinzel',serif;font-size:0.82rem;font-weight:700;width:22px;text-align:center;color:var(--text3)}
.lb-rank.r1{color:#f59e0b}.lb-rank.r2{color:#94a3b8}.lb-rank.r3{color:#cd7f32}
.lb-name{flex:1;font-size:0.88rem}
.lb-val{font-family:'Cinzel',serif;font-size:0.82rem;color:var(--gold2)}
.lb-you{font-size:0.65rem;color:var(--text3)}

/* ── PROFILE ── */
.profile-hero{background:linear-gradient(135deg,var(--surface),var(--surface2));
  border:1px solid var(--border2);border-radius:12px;padding:1.2rem;text-align:center;margin-bottom:0.7rem}
.profile-ava{width:80px;height:80px;margin:0 auto 0.5rem;font-size:4rem;
  display:flex;align-items:center;justify-content:center;overflow:hidden;border-radius:12px}
.profile-ava img{width:80px;height:80px;object-fit:cover;border-radius:12px}
.profile-name{font-family:'Cinzel',serif;font-size:1.3rem;color:var(--gold2);font-weight:700}
.profile-level{color:var(--text3);font-size:0.88rem;margin-bottom:0.75rem}
.profile-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.5rem}
.ps-item{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:0.5rem;text-align:center}
.ps-val{font-family:'Cinzel',serif;font-size:1rem;color:var(--steel2);font-weight:600}
.ps-key{font-size:0.65rem;color:var(--text3);margin-top:0.1rem}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.82);
  display:flex;align-items:center;justify-content:center;z-index:500;
  padding:1rem;backdrop-filter:blur(6px)}
.modal{background:var(--surface);border:1px solid var(--border2);border-radius:16px;
  padding:1.4rem;width:100%;max-width:340px;box-shadow:0 30px 80px rgba(0,0,0,0.7);
  max-height:90vh;overflow-y:auto}
@keyframes modalIn{from{opacity:0;transform:scale(0.88) translateY(20px)}to{opacity:1;transform:scale(1) translateY(0)}}
.modal{animation:modalIn 0.22s ease}
.modal-title{font-family:'Cinzel',serif;font-size:1.05rem;font-weight:700;
  color:var(--gold2);text-align:center;margin-bottom:0.5rem}
.modal-icon{width:72px;height:72px;margin:0 auto 0.4rem;display:flex;align-items:center;justify-content:center;font-size:3.5rem}
.modal-icon img{width:72px;height:72px;object-fit:contain}
.modal-rarity{font-family:'Cinzel',serif;font-size:0.72rem;text-transform:uppercase;
  letter-spacing:0.1em;text-align:center;margin-bottom:1rem}
.modal-row{display:flex;justify-content:space-between;align-items:center;
  padding:0.4rem 0;border-bottom:1px solid var(--border);font-size:0.88rem}
.modal-row:last-of-type{border-bottom:none}
.modal-row em{color:var(--text3);font-style:normal}
.modal-actions{margin-top:1rem;display:flex;flex-direction:column;gap:0}
.modal-input{width:100%;padding:0.65rem 0.8rem;background:var(--bg3);border:1px solid var(--border);
  border-radius:8px;color:var(--text);font-family:'Crimson Pro',serif;font-size:1rem;
  outline:none;margin-bottom:0.6rem}
.modal-input:focus{border-color:var(--gold)}

/* ── COMBAT ── */
.combat-scene{background:linear-gradient(180deg,#0a1a2e,#0f2040 40%,var(--bg3) 100%);
  border:1px solid var(--border2);border-radius:12px;padding:1rem;margin-bottom:0.7rem;text-align:center}
.fighters{display:flex;align-items:flex-end;justify-content:space-around;margin-bottom:0.75rem}
.fighter{display:flex;flex-direction:column;align-items:center;gap:0.2rem;min-width:85px}
.f-img{width:56px;height:56px;display:flex;align-items:center;justify-content:center;font-size:2.8rem;line-height:1}
.f-img img{width:56px;height:56px;object-fit:contain}
.f-name{font-family:'Cinzel',serif;font-size:0.65rem;color:var(--text2);text-align:center}
.f-hp{font-size:0.82rem;color:var(--text);font-weight:600}
.f-bar{width:70px;height:5px;background:rgba(0,0,0,0.4);border-radius:3px;overflow:hidden}
.f-bar-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--crimson),var(--crimson2));transition:width 0.4s}
.vs{font-family:'Cinzel',serif;font-size:1.3rem;font-weight:900;color:var(--crimson2);
  text-shadow:0 0 20px rgba(224,64,64,0.6);align-self:center}
.combat-log{background:rgba(0,0,0,0.4);border:1px solid var(--border);border-radius:8px;
  padding:0.7rem;font-size:0.8rem;color:var(--text2);min-height:70px;max-height:110px;
  overflow-y:auto;line-height:1.7;margin-bottom:0.7rem;text-align:left}
.combat-log::-webkit-scrollbar{width:2px}
.log-hit{color:var(--crimson2)}.log-crit{color:var(--gold2);font-weight:600}
.log-you{color:var(--steel2)}.log-win{color:var(--green2);font-weight:600}
.log-lose{color:var(--crimson2);font-weight:600}.log-sys{color:var(--text3)}

/* ── TOAST ── */
#toast-container{position:fixed;top:60px;left:50%;transform:translateX(-50%);
  z-index:600;display:flex;flex-direction:column;gap:0.4rem;
  pointer-events:none;width:88%;max-width:400px}
.toast{background:var(--surface2);border:1px solid var(--border2);border-radius:10px;
  padding:0.65rem 1rem;font-size:0.88rem;text-align:center;box-shadow:0 4px 20px rgba(0,0,0,0.5)}
@keyframes toastIn{from{opacity:0;transform:translateY(-8px) scale(0.94)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes toastOut{to{opacity:0;transform:translateY(-8px)}}
.toast{animation:toastIn 0.25s ease}
.toast.dying{animation:toastOut 0.25s ease forwards}

/* ── MISC ── */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:0.5rem}
.info-box{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:0.6rem;text-align:center}
.info-box-val{font-family:'Cinzel',serif;font-size:1rem;color:var(--gold2);font-weight:600}
.info-box-key{font-size:0.65rem;color:var(--text3);margin-top:0.1rem}
.pill{display:inline-block;padding:0.15rem 0.5rem;border-radius:20px;font-size:0.7rem;
  font-family:'Cinzel',serif;font-weight:600;letter-spacing:0.04em}
</style>
</head>
<body>
<div id="toast-container"></div>
<div id="app">

  <!-- AUTH -->
  <div id="auth-screen" class="screen active">
    <div class="auth-logo-text">⚔ MicroMMO</div>
    <div class="auth-logo-sub">Battle · Explore · Conquer</div>
    <div class="auth-card">
      <div class="tab-row">
        <button class="tab-btn active" id="tab-login" onclick="G.switchAuthTab('login')">Login</button>
        <button class="tab-btn" id="tab-register" onclick="G.switchAuthTab('register')">Register</button>
      </div>
      <div id="auth-error" class="error-box" style="display:none"></div>
      <div id="reg-username-group" class="form-group" style="display:none">
        <label class="form-label">Hero Name</label>
        <input class="form-input" id="reg-username" placeholder="Your legend name" maxlength="20"/>
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input class="form-input" id="auth-email" type="email" placeholder="hero@realm.com"/>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input class="form-input" id="auth-password" type="password" placeholder="••••••••"/>
      </div>
      <button class="btn btn-steel" onclick="G.handleEmailAuth()">Enter the Realm</button>
      <div class="divider">or</div>
      <button class="btn btn-gold" onclick="G.handleGoogleAuth()">🔵 Continue with Google</button>
    </div>
  </div>

  <!-- USERNAME -->
  <div id="username-screen" class="screen">
    <div class="auth-card">
      <div class="modal-title">⚔️ Name Your Hero</div>
      <p style="text-align:center;color:var(--text3);font-size:0.88rem;margin-bottom:1rem">What shall the realm call you?</p>
      <div class="form-group">
        <input class="form-input" id="new-username" placeholder="Your legend name" maxlength="20"/>
      </div>
      <button class="btn btn-steel" onclick="G.handleSetUsername()">Begin Journey</button>
    </div>
  </div>

  <!-- GAME -->
  <div id="game-screen" class="screen">
    <div id="header">
      <div class="hdr-logo">⚔ MicroMMO</div>
      <div class="hdr-level" id="hdr-level">Lv.1</div>
      <div class="hdr-hp" id="hdr-hp">❤️ 110</div>
      <div class="hdr-avatar" onclick="G.showTab('you')" id="hdr-avatar-el">🧙</div>
    </div>
    <div id="content"></div>
    <div id="nav">
      <button class="nav-btn active" id="nav-home" onclick="G.showTab('home')">
        <span class="nav-icon">🏠</span>Home
      </button>
      <button class="nav-btn" id="nav-gear" onclick="G.showTab('gear')">
        <span class="nav-icon">🎒</span>Gear
      </button>
      <div class="nav-center">
        <div class="nav-walk" id="nav-walk" onclick="G.takeStep()">⚔️</div>
      </div>
      <button class="nav-btn" id="nav-market" onclick="G.showTab('market')">
        <span class="nav-icon">🏪</span>Market
      </button>
      <button class="nav-btn" id="nav-social" onclick="G.showTab('social')">
        <span class="nav-icon">👥</span>Social
      </button>
    </div>
  </div>

</div>
<div id="modal-overlay" class="modal-overlay" style="display:none" onclick="G.closeModal()">
  <div class="modal" onclick="event.stopPropagation()" id="modal-content"></div>
</div>
<script src="game.js" type="module"></script>
</body>
</html>
